<UserControl x:Class="PDFMerger.Controls.ExtractTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid Margin="16,14,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Extract Pages as Images" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Load a PDF, select pages to extract, choose a format and DPI, then save as images."
                       Style="{StaticResource PageSubtitle}" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Browse PDF…" Click="BrowsePdf_Click" Padding="12,6" Margin="0,0,10,0" />
                <TextBlock x:Name="FileNameLabel" VerticalAlignment="Center"
                           Text="No file loaded"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- Options -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}"
                Padding="12,10" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Format:" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,10,0" />
                <RadioButton x:Name="PngRadio" Content="PNG" IsChecked="True"
                             Margin="0,0,14,0" VerticalAlignment="Center" />
                <RadioButton x:Name="JpgRadio" Content="JPG"
                             Margin="0,0,24,0" VerticalAlignment="Center" />
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="0,2,20,2" />
                <TextBlock Text="DPI:" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,10,0" />
                <TextBox x:Name="DpiBox" Text="150" Width="64"
                         VerticalAlignment="Center" TextAlignment="Center"
                         PreviewTextInput="DpiBox_PreviewTextInput" />
                <TextBlock Text="(72 – 600)" VerticalAlignment="Center"
                           FontSize="11" Margin="8,0,0,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
        </Border>

        <!-- Body: page list + preview -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="270" />
            </Grid.ColumnDefinitions>

            <!-- Page list -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}"
                    Margin="0,0,10,0">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top" Text="PAGES"
                               Style="{StaticResource SectionHeader}" />
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <Button Content="Select All" Click="SelectAll_Click"
                                Padding="12,6" Margin="0,0,6,0" />
                        <Button Content="Clear Selection" Click="ClearSelection_Click"
                                Padding="12,6" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Select pages to extract — leave empty to extract all pages"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,0,6" />
                    <ListBox x:Name="PageListBox" SelectionMode="Extended"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="PageListBox_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource DefaultListBoxItemStyle}">
                                <Setter Property="Padding" Value="10,6" />
                                <Setter Property="Margin" Value="0,1" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Preview card -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="PREVIEW"
                               Style="{StaticResource SectionHeader}" />
                    <TextBlock x:Name="PreviewInfoText" DockPanel.Dock="Bottom"
                               Text="Click a page to preview"
                               FontSize="11" HorizontalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap" Margin="0,8,0,0" />
                    <Border Style="{StaticResource PreviewArea}">
                        <Image x:Name="PreviewImage" Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="6" />
                    </Border>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Primary action -->
        <Button Grid.Row="3" Content="Extract Pages as Images"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Left" Padding="24,10" FontSize="14"
                Margin="0,12,0,0" Click="Extract_Click" />
    </Grid>
</UserControl>
