<UserControl x:Class="PDFMerger.Controls.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,12" MaxWidth="600">

            <!-- Appearance section -->
            <TextBlock Text="Appearance"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <Separator Margin="0,0,0,10" />

            <TextBlock Text="Theme" FontSize="13" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <RadioButton x:Name="LightThemeRadio"
                             Content="Light"
                             Margin="0,0,16,0"
                             IsChecked="True"
                             Checked="ThemeRadio_Checked" />
                <RadioButton x:Name="DarkThemeRadio"
                             Content="Dark"
                             Checked="ThemeRadio_Checked" />
            </StackPanel>

            <!-- Output section -->
            <TextBlock Text="Output"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <Separator Margin="0,0,0,10" />

            <!-- Default output folder -->
            <TextBlock Text="Default Output Folder"
                       FontSize="13" Margin="0,0,0,6" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="OutputFolderBox"
                         Grid.Column="0"
                         Margin="0,0,8,0"
                         IsReadOnly="False"
                         TextChanged="OutputFolderBox_TextChanged" />
                <Button Grid.Column="1"
                        Content="Browse…"
                        Padding="10,6"
                        Click="BrowseFolder_Click" />
            </Grid>

            <!-- Default merge filename -->
            <TextBlock Text="Default Merge Filename (without extension)"
                       FontSize="13" Margin="0,0,0,6" />
            <TextBox x:Name="MergeFilenameBox"
                     Margin="0,0,0,12"
                     TextChanged="MergeFilenameBox_TextChanged" />

            <!-- Auto-open folder -->
            <CheckBox x:Name="AutoOpenCheckBox"
                      Content="Automatically open output folder after saving"
                      Margin="0,0,0,12"
                      Checked="AutoOpenCheckBox_Changed"
                      Unchecked="AutoOpenCheckBox_Changed" />

            <!-- Info -->
            <TextBlock Text="Settings are saved automatically."
                       Foreground="Gray" FontSize="11"
                       Margin="0,16,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
