<UserControl x:Class="PDFMerger.Controls.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,14" MaxWidth="620">

            <!-- Page title -->
            <TextBlock Text="Settings" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Preferences are saved automatically as you change them."
                       Style="{StaticResource PageSubtitle}" />

            <!-- Appearance card -->
            <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeader}" Margin="0,8,0,6" />
            <Border Style="{StaticResource CardBorder}" Padding="16,14" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Theme" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource CardBorder}" Padding="14,10" Margin="0,0,8,0"
                                MinWidth="120">
                            <RadioButton x:Name="LightThemeRadio" Content="☀  Light"
                                         IsChecked="True" Checked="ThemeRadio_Checked"
                                         FontSize="13" />
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Padding="14,10"
                                MinWidth="120">
                            <RadioButton x:Name="DarkThemeRadio" Content="🌙  Dark"
                                         Checked="ThemeRadio_Checked"
                                         FontSize="13" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output card -->
            <TextBlock Text="OUTPUT" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
            <Border Style="{StaticResource CardBorder}" Padding="16,14" Margin="0,0,0,16">
                <StackPanel>

                    <!-- Default folder -->
                    <TextBlock Text="Default Output Folder" FontWeight="SemiBold"
                               FontSize="13" Margin="0,0,0,6" />
                    <TextBlock Text="Used as the starting directory in Save dialogs."
                               FontSize="11" Margin="0,0,0,8"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OutputFolderBox" Grid.Column="0"
                                 Margin="0,0,8,0" IsReadOnly="False"
                                 TextChanged="OutputFolderBox_TextChanged" />
                        <Button Grid.Column="1" Content="Browse…"
                                Padding="12,6" Click="BrowseFolder_Click" />
                    </Grid>

                    <!-- Default merge filename -->
                    <TextBlock Text="Default Merge Filename" FontWeight="SemiBold"
                               FontSize="13" Margin="0,0,0,6" />
                    <TextBlock Text="Pre-filled name in the Save dialog when merging (no extension needed)."
                               FontSize="11" Margin="0,0,0,8"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBox x:Name="MergeFilenameBox" MaxWidth="280"
                             HorizontalAlignment="Left" Margin="0,0,0,16"
                             TextChanged="MergeFilenameBox_TextChanged" />

                    <!-- Auto open -->
                    <CheckBox x:Name="AutoOpenCheckBox"
                              Content="Automatically open output folder after saving"
                              FontSize="13"
                              Checked="AutoOpenCheckBox_Changed"
                              Unchecked="AutoOpenCheckBox_Changed" />
                </StackPanel>
            </Border>

            <!-- About card -->
            <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
            <Border Style="{StaticResource CardBorder}" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="PDF &amp; Image Merger" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock Text="Version 1.0.0  —  C# / WPF port"
                               FontSize="11" Margin="0,4,0,2"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="© 2026 Ricardo Scollo. All rights reserved."
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
