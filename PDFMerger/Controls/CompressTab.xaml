<UserControl x:Class="PDFMerger.Controls.CompressTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Compress PDF"
                       FontSize="20" FontWeight="Bold" />
            <TextBlock Text="Load a PDF and choose a compression level to reduce file size."
                       Foreground="Gray" FontSize="12" Margin="0,2,0,6" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Browse PDF…" Click="BrowsePdf_Click" Padding="10,6" Margin="0,0,8,0" />
                <TextBlock x:Name="FileNameLabel"
                           VerticalAlignment="Center"
                           Text="No file loaded"
                           Foreground="Gray" />
            </StackPanel>
        </StackPanel>

        <!-- Compression level selection -->
        <GroupBox Grid.Row="1" Header="Compression Level" Margin="0,0,0,12" Padding="12,8">
            <StackPanel>
                <RadioButton x:Name="LowRadio"
                             IsChecked="True"
                             Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Low — Fastest" FontWeight="SemiBold" />
                        <TextBlock Text="Minimal compression. Fastest processing, larger output file."
                                   Foreground="Gray" FontSize="11" />
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="MediumRadio" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Medium — Balanced" FontWeight="SemiBold" />
                        <TextBlock Text="Good compression with smart mode. Balances size and speed."
                                   Foreground="Gray" FontSize="11" />
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="HighRadio">
                    <StackPanel>
                        <TextBlock Text="High — Best Compression" FontWeight="SemiBold" />
                        <TextBlock Text="Maximum compression with smart mode. Smallest output, slowest processing."
                                   Foreground="Gray" FontSize="11" />
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </GroupBox>

        <!-- Size comparison label -->
        <Border Grid.Row="2"
                x:Name="SizeResultBorder"
                Visibility="Collapsed"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                BorderThickness="1" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,12"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock x:Name="SizeLabel"
                       FontSize="13"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Spacer -->
        <Grid Grid.Row="3" />

        <!-- Compress & Save button -->
        <Button Grid.Row="4"
                Content="Compress &amp; Save"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Left"
                Padding="20,8"
                FontSize="14"
                Click="CompressSave_Click" />
    </Grid>
</UserControl>
