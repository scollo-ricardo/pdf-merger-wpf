<UserControl x:Class="PDFMerger.Controls.SplitTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid Margin="16,14,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Split PDF" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Load a PDF, then drag pages from the source column into output columns to define each split."
                       Style="{StaticResource PageSubtitle}" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Browse PDF…" Click="BrowsePdf_Click" Padding="12,6" Margin="0,0,10,0" />
                <TextBlock x:Name="FileNameLabel" VerticalAlignment="Center"
                           Text="No file loaded"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- Column count -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}"
                Padding="12,8" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Output columns:" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,12,0" />
                <Button Content="−" Width="32" Height="32" Padding="0"
                        FontSize="16" Click="DecrColumns_Click" Margin="0,0,6,0" />
                <TextBlock x:Name="ColumnCountLabel" Text="2"
                           Width="28" TextAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16" FontWeight="Bold" />
                <Button Content="+" Width="32" Height="32" Padding="0"
                        FontSize="16" Click="IncrColumns_Click" Margin="6,0,0,0" />
                <TextBlock Text="  (drag pages from Source into each output column)"
                           VerticalAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="16,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Body: preview + columns -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Preview card -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}"
                    Padding="12" Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="PREVIEW"
                               Style="{StaticResource SectionHeader}" />
                    <TextBlock x:Name="PreviewInfoText" DockPanel.Dock="Bottom"
                               Text="Click a page to preview"
                               FontSize="11" HorizontalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap" Margin="0,8,0,0" />
                    <Border Style="{StaticResource PreviewArea}">
                        <Image x:Name="PreviewImage" Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="6" />
                    </Border>
                </DockPanel>
            </Border>

            <!-- Columns -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ColumnsPanel" Orientation="Horizontal"
                                Margin="8" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Primary action -->
        <Button Grid.Row="3" Content="Split &amp; Save"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Left" Padding="24,10" FontSize="14"
                Margin="0,12,0,0" Click="SplitSave_Click" />
    </Grid>
</UserControl>
