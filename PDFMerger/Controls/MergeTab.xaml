<UserControl x:Class="PDFMerger.Controls.MergeTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="PDF &amp; Image Merger"
                       FontSize="20" FontWeight="Bold" />
            <TextBlock Text="Drag &amp; drop files or use Add Files button to queue PDFs and images for merging."
                       Foreground="Gray" FontSize="12" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Body: file list + preview -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- File list -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4" Margin="0,0,8,0">
                <ListBox x:Name="FileListBox"
                         AllowDrop="True"
                         SelectionMode="Extended"
                         BorderThickness="0"
                         Drop="FileListBox_Drop"
                         DragEnter="FileListBox_DragEnter"
                         DragOver="FileListBox_DragOver"
                         SelectionChanged="FileListBox_SelectionChanged"
                         MouseLeftButtonDown="FileListBox_MouseLeftButtonDown"
                         MouseMove="FileListBox_MouseMove"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="8,4" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>

            <!-- Preview panel -->
            <Border Grid.Column="1" Width="260"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="8">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="Preview" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6" />

                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                            MinHeight="300">
                        <Image x:Name="PreviewImage"
                               MaxWidth="230" MaxHeight="380"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="4" />
                    </Border>

                    <TextBlock x:Name="PreviewInfoText"
                               Text="No file selected"
                               FontSize="11"
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,6"
                               TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="PrevPageBtn" Content="◀"
                                Width="36" Margin="0,0,4,0"
                                IsEnabled="False"
                                Click="PrevPageBtn_Click" />
                        <TextBlock x:Name="PageNavLabel"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Margin="4,0"
                                   Text="" />
                        <Button x:Name="NextPageBtn" Content="▶"
                                Width="36" Margin="4,0,0,0"
                                IsEnabled="False"
                                Click="NextPageBtn_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Toolbar buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,8">
            <Button Content="Add Files" Click="AddFiles_Click" Margin="0,0,6,0" Padding="10,6" />
            <Button Content="Move Up" Click="MoveUp_Click" Margin="0,0,6,0" Padding="10,6" />
            <Button Content="Move Down" Click="MoveDown_Click" Margin="0,0,6,0" Padding="10,6" />
            <Button Content="Remove" Click="Remove_Click" Margin="0,0,6,0" Padding="10,6" />
            <Button Content="Clear All" Click="ClearAll_Click" Padding="10,6" />
        </StackPanel>

        <!-- Merge button -->
        <Button Grid.Row="3"
                Content="Merge Files"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Left"
                Padding="20,8"
                FontSize="14"
                Click="MergeFiles_Click" />
    </Grid>
</UserControl>
