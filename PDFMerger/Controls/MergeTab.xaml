<UserControl x:Class="PDFMerger.Controls.MergeTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid Margin="16,14,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="PDF &amp; Image Merger" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Drag &amp; drop files below or use Add Files. Reorder by dragging. Select a file to preview."
                       Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <!-- Body: list + preview -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="270" />
            </Grid.ColumnDefinitions>

            <!-- File list -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <Grid>
                    <!-- Empty state hint -->
                    <StackPanel x:Name="DropHint" VerticalAlignment="Center"
                                HorizontalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="42" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="Drop PDF or image files here"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Text="or use the Add Files button below"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <ListBox x:Name="FileListBox"
                             AllowDrop="True" SelectionMode="Extended"
                             BorderThickness="0" Background="Transparent"
                             Drop="FileListBox_Drop"
                             DragEnter="FileListBox_DragEnter"
                             DragOver="FileListBox_DragOver"
                             SelectionChanged="FileListBox_SelectionChanged"
                             MouseLeftButtonDown="FileListBox_MouseLeftButtonDown"
                             MouseMove="FileListBox_MouseMove"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Padding="4">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource DefaultListBoxItemStyle}">
                                <Setter Property="Padding" Value="10,7" />
                                <Setter Property="Margin" Value="0,1" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border CornerRadius="3" Padding="5,2" Margin="0,0,10,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#0078D4" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                        <Setter Property="Background" Value="#107C10" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Tag}" FontSize="10"
                                                   FontWeight="Bold" Foreground="White" />
                                    </Border>
                                    <TextBlock Text="{Binding FileName}"
                                               VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Preview card -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="PREVIEW"
                               Style="{StaticResource SectionHeader}" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <TextBlock x:Name="PreviewInfoText"
                                   Text="Select a file to preview"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="PrevPageBtn" Content="◀" Width="34"
                                    IsEnabled="False" Padding="0" Margin="0,0,8,0"
                                    Click="PrevPageBtn_Click" />
                            <TextBlock x:Name="PageNavLabel" VerticalAlignment="Center"
                                       FontSize="11" MinWidth="50" TextAlignment="Center" />
                            <Button x:Name="NextPageBtn" Content="▶" Width="34"
                                    IsEnabled="False" Padding="0" Margin="8,0,0,0"
                                    Click="NextPageBtn_Click" />
                        </StackPanel>
                    </StackPanel>
                    <Border Style="{StaticResource PreviewArea}">
                        <Image x:Name="PreviewImage" Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="6" />
                    </Border>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Toolbar -->
        <WrapPanel Grid.Row="2" Margin="0,10,0,10">
            <Button Content="Add Files"  Style="{StaticResource ToolbarButton}" Click="AddFiles_Click" />
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                       Margin="2,2,8,2" />
            <Button Content="Move Up"   Style="{StaticResource ToolbarButton}" Click="MoveUp_Click" />
            <Button Content="Move Down" Style="{StaticResource ToolbarButton}" Click="MoveDown_Click" />
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                       Margin="2,2,8,2" />
            <Button Content="Remove"    Style="{StaticResource ToolbarButton}" Click="Remove_Click" />
            <Button Content="Clear All" Style="{StaticResource ToolbarButton}" Click="ClearAll_Click" />
        </WrapPanel>

        <!-- Primary action -->
        <Button Grid.Row="3" Content="Merge Files"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Left" Padding="24,10" FontSize="14"
                Click="MergeFiles_Click" />
    </Grid>
</UserControl>
