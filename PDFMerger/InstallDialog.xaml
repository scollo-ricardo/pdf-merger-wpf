<Window x:Class="PDFMerger.InstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Install PDF Merger"
        Icon="Assets/icon.ico"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <Image Source="Assets/logo.png" Width="56" Height="56" Margin="0,0,14,0"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Welcome to PDF Merger"
                           FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Install this app on your PC for easy access from the Desktop and Start Menu."
                           FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Install location -->
        <TextBlock Grid.Row="1" Text="INSTALL LOCATION"
                   FontSize="11" FontWeight="SemiBold" Foreground="Gray"
                   Margin="0,0,0,6" />
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="LocationBox" Grid.Column="0" Margin="0,0,8,0" />
            <Button Grid.Column="1" Content="Browse..." Padding="14,6" Click="Browse_Click" />
        </Grid>

        <!-- Shortcut options -->
        <StackPanel Grid.Row="3" Margin="0,18,0,0">
            <CheckBox x:Name="DesktopCheck" Content="Create desktop shortcut" IsChecked="True" />
            <CheckBox x:Name="StartMenuCheck" Content="Add to Start Menu" IsChecked="True" Margin="0,8,0,0" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
            <Button Content="Run without installing"
                    Padding="14,8" Margin="0,0,8,0" Click="RunOnce_Click" />
            <Button Content="Install"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="20,8" FontWeight="SemiBold"
                    Click="Install_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
